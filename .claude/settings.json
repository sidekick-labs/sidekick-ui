{
  "permissions": {
    "allow": [
      "mcp__linear__create_comment",
      "mcp__linear__create_issue",
      "mcp__linear__create_issue_label",
      "mcp__linear__get_issue",
      "mcp__linear__get_project",
      "mcp__linear__list_comments",
      "mcp__linear__list_issue_labels",
      "mcp__linear__list_issue_statuses",
      "mcp__linear__list_issues",
      "mcp__linear__list_projects",
      "mcp__linear__list_teams",
      "mcp__linear__list_users",
      "mcp__linear__search_documentation",
      "mcp__linear__update_issue",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git merge-base:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rm:*)",
      "Bash(git stash:*)",
      "Bash(gh api:*)",
      "Bash(gh issue list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run build:*)",
      "Bash(npm run check:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(npm pack:*)",
      "Bash(SKIP_PRE_PUSH_HOOK=1 git push:*)",
      "Bash(SKIP_PRE_PUSH_PREPARE=1 git push:*)",
      "Bash(ALLOW_MULTIPLE_COMMITS=1 git push:*)",
      "Bash(ALLOW_MULTIPLE_COMMITS=1 gh pr create:*)",
      "Skill(worktree)",
      "Bash(git worktree:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-prepare.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-signed-commits.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-lint.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
